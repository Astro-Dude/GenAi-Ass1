# Google Gemini API key — get one from https://aistudio.google.com/app/apikey
# Never commit your real key. Copy this file to .env.local and fill in the value.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default model. Defaults to gemini-2.5-flash if unset.
# Other valid options: gemini-2.0-flash, gemini-2.5-flash-lite, gemini-2.5-pro
# GEMINI_MODEL=gemini-2.5-flash
